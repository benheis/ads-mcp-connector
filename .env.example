# ─────────────────────────────────────────────────────────────
# ads-mcp-connector — credentials template
#
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
#
# The easiest way to set these up: open Claude Code and
# type /ads-connect — the skill will walk you through it.
# ─────────────────────────────────────────────────────────────

# ─── META ADS ─────────────────────────────────────────────────
#
# Recommended: System User token from Meta Business Manager
#   Business Settings → System Users → Generate Token
#   Set expiration to "Never" — you'll never need to renew it
#
# Fallback: Long-lived token from Graph API Explorer
#   developers.facebook.com/tools/explorer
#   Expires every 60 days
#
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=          # Format: act_XXXXXXXXXX (from Ads Manager URL)

# ─── GOOGLE ADS ───────────────────────────────────────────────
#
# Developer token: ads.google.com/aw/apicenter
# OAuth credentials: console.cloud.google.com → APIs & Services → Credentials
# Refresh token: run `python get_google_token.py` after setting client ID/secret
#
GOOGLE_DEVELOPER_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CUSTOMER_ID=          # 10-digit number, no dashes (from Google Ads header)
GOOGLE_LOGIN_CUSTOMER_ID=    # Optional: only needed if using a manager (MCC) account
